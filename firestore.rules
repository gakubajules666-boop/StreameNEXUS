rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Profiles Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId &&
        incoming().uid == request.auth.uid &&
        incoming().role == "user" && // Default to standard role
        incoming().createdAt is string &&
        incoming().displayName is string &&
        incoming().displayName.size() <= 100;
        
      allow update: if isSignedIn() && request.auth.uid == userId &&
        incoming().uid == existing().uid &&
        incoming().role == existing().role && // Prevent privilege self-escalation
        incoming().createdAt == existing().createdAt;
    }

    // --- Admin Whitelist ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Video Catalog Collection ---
    match /videos/{videoId} {
      allow read: if true; // Public access
      allow create: if isSignedIn() && isValidId(videoId) &&
        incoming().creatorId == request.auth.uid &&
        incoming().approved == false && // Must seek admin moderation approval
        incoming().status == "pending" &&
        incoming().views == 0 &&
        incoming().createdAt is string;

      allow update: if isSignedIn() && (
        isAdmin() || (
          existing().creatorId == request.auth.uid &&
          incoming().creatorId == existing().creatorId &&
          incoming().views == existing().views &&
          incoming().approved == existing().approved &&
          incoming().status == existing().status &&
          incoming().createdAt == existing().createdAt &&
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'thumbnailUrl', 'category', 'isPremium', 'hasAds', 'likes', 'dislikes'])
        ) || (
          // Allow viewers to only change likes/dislikes arrays and view playcounts
          incoming().diff(existing()).affectedKeys().hasAny(['likes', 'dislikes', 'views']) &&
          incoming().creatorId == existing().creatorId &&
          incoming().title == existing().title &&
          incoming().videoUrl == existing().videoUrl &&
          incoming().approved == existing().approved &&
          incoming().status == existing().status
        )
      );

      allow delete: if isSignedIn() && (isAdmin() || existing().creatorId == request.auth.uid);

      // --- Comments Nested Subcollection ---
      match /comments/{commentId} {
        allow read: if true; // Public list
        allow create: if isSignedIn() && isValidId(commentId) &&
          incoming().userId == request.auth.uid &&
          incoming().text is string &&
          incoming().text.size() <= 1000;
        allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      }
    }

    // --- Direct Donations Payment Collection ---
    match /donations/{donationId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        incoming().donorName is string &&
        incoming().amount > 0 &&
        incoming().amount <= 10000;
      allow update, delete: if isAdmin();
    }

    // --- Nested Watch Playback Histories Tracker ---
    match /users/{userId}/watchHistory/{historyId} {
      allow read, write: if isOwner(userId);
    }
  }
}
